{
    "preset": "laravel",
    "exclude": [
        ".github",
        "bootstrap",
        "public",
        "resources",
        "storage",
        "vendor",
        "node_modules"
    ],
    "rules": {
        "trailing_comma_in_multiline": {
            "elements": []
        },
        "concat_space": {
            "spacing": "one"
        },
        "not_operator_with_successor_space": false,
        "single_quote": false,
        "nullable_type_declaration_for_default_null_value": false,
        "fully_qualified_strict_types": {
            "import_symbols": true
        },

        "no_spaces_after_function_name": false
    }
}
